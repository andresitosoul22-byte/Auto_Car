rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /users/{uid} {
      // El propio usuario lee su perfil; el admin lista todos los perfiles desde el panel.
      allow read: if isSelf(uid) || isAdmin();
      allow create: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.role in ["cliente", "admin"];

      allow update: if isSelf(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.role in ["cliente", "admin"];
    }

    match /vehicles/{vehicleId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /contracts/{contractId} {
      // Cliente: solo sus contratos. Admin: todos (listado y revision).
      allow read: if signedIn()
        && (resource.data.ownerUid == request.auth.uid || isAdmin());

      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid;

      // Cliente actualiza/borra los suyos; admin actualiza estado (aprobar, declinar, cancelar).
      allow update: if isAdmin()
        || (signedIn() && resource.data.ownerUid == request.auth.uid);

      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /password_recovery_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}
